local function Clark()
	if not walkTrack or not idleTrack then
		--Анимок нету
		return
	end
	if not humanoid then
		--Мабосика нету
		return
	end
	isCustom = not isCustom
	if isCustom then
		ClarkButton.Text = "ON"
		humanoid.WalkSpeed = 5
		if runningConnection then runningConnection:Disconnect() end
		runningConnection = humanoid.Running:Connect(function(speed)
			if speed > 0 then
				if walkTrack and not walkTrack.IsPlaying then walkTrack:Play() end
				if idleTrack and idleTrack.IsPlaying then idleTrack:Stop() end
			else
				if idleTrack and not idleTrack.IsPlaying then idleTrack:Play() end
				if walkTrack and walkTrack.IsPlaying then walkTrack:Stop() end
			end
		end)
		if humanoid.MoveDirection.Magnitude > 0 then
			walkTrack:Play()
			idleTrack:Stop()
		else
			idleTrack:Play()
			walkTrack:Stop()
		end
	else
		ClarkButton.Text = "OFF"
		if runningConnection then
			runningConnection:Disconnect()
			runningConnection = nil
		end
		walkTrack:Stop()
		idleTrack:Stop()
		humanoid.WalkSpeed = 16
	end
end

